#nexus

BEGIN Taxa;
DIMENSIONS ntax=4;
TAXLABELS
[1] 'Cx_molestus'
[2] 'Cx_pallens'
[3] 'Cx_pipiens'
[4] 'Cx_quinquefasciatus'
;
END; [Taxa]

BEGIN Splits;
DIMENSIONS ntax=4 nsplits=5;
FORMAT labels=no weights=yes confidences=no intervals=no;
MATRIX
	100	 2,
	100	 4,
	100	 1 3,
	100	 3,
	100	 1,
;
END; [Splits]

